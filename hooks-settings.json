{
  "_comment": "Merge the 'hooks' block into your Claude Code settings.json (e.g. %USERPROFILE%\\.claude\\settings.json). Replace <PROJECT_DIR> with this repo's absolute path (use doubled backslashes), or just paste the snippet setup.ps1 prints with the paths already filled in. SessionStart starts the warm TTS daemon; Stop/Notification/PreToolUse speak replies, prompts, and questions.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"<PROJECT_DIR>\\.venv\\Scripts\\pythonw.exe\" \"<PROJECT_DIR>\\src\\launch_server.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"<PROJECT_DIR>\\.venv\\Scripts\\python.exe\" \"<PROJECT_DIR>\\src\\speak.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"<PROJECT_DIR>\\.venv\\Scripts\\python.exe\" \"<PROJECT_DIR>\\src\\speak.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "\"<PROJECT_DIR>\\.venv\\Scripts\\python.exe\" \"<PROJECT_DIR>\\src\\speak.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
